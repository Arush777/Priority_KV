# Copy to .env and fill in. NEVER commit .env.

# --- Identity (each collaborator sets their own) ---
AGENT_ID=arush
# Friend should use: AGENT_ID=friend
# Or a short handle you both agree on (lowercase, no spaces).

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: only process messages after this update_id on first run
# TELEGRAM_BOOTSTRAP_OFFSET=

# --- Cursor (required for live agent ticks) ---
CURSOR_API_KEY=
# Model id available on your plan, e.g. composer-2.5
CURSOR_MODEL=composer-2.5

# --- Project ---
# Absolute path to this repo checkout on THIS machine
REPO_ROOT=
# GitHub remote (used in prompts / status messages)
GITHUB_REPO=Arush777/Information_Retrieval
GITHUB_DEFAULT_BRANCH=main

# --- Bridge behavior ---
# Seconds between ticks when running `python -m collab_bridge daemon`
TICK_INTERVAL_SEC=3600
# Max Telegram messages fed into one agent turn
MAX_MESSAGES_PER_TICK=40
# Max agent wall-clock seconds (soft target; runner still waits on SDK)
AGENT_TIMEOUT_SEC=1800
# Dry-run posts a plan to Telegram without calling Cursor SDK
DRY_RUN=0
# If 1, agent may propose scope changes; humans/partner must ACK via Telegram
REQUIRE_SCOPE_ACK=1

# --- Safety rails ---
# Comma-separated; if seen in a Telegram message from a human, bridge pauses
STOP_KEYWORDS=STOP_BRIDGE,HALT_AGENTS
MAX_COMMITS_PER_TICK=5
BRANCH_PREFIX=
# Defaults to agent/<AGENT_ID>/ if empty
