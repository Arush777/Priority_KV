# Copy to .env on each machine. NEVER commit .env.

REPO_ROOT=
PRIORITYKV_SCRATCH=
HF_TOKEN=
HF_HOME=

# Two-GPU cap on shared hosts (physical indices). Override only if these are busy.
CUDA_VISIBLE_DEVICES=6,7

# H200 toolkit for torch JIT / quanto_cuda (set on GPU box)
# CUDA_HOME=/usr/local/cuda
# TORCH_CUDA_ARCH_LIST=9.0

# Local → H200 fetch_results.sh (agent machine only)
# H200_HOST=anupam@169.38.10.80
# H200_SCRATCH=/data/anupam/scratch/prioritykv

# remote_worker.sh (H200 only)
# REMOTE_WORKER_POLL_SEC=45
# REMOTE_WORKER_BRANCH=main
# REMOTE_WORKER_PUSH_STATUS=1
