#!/usr/bin/env python3
"""Figures for EXTERNAL_BFCL_PRAJNA_V1, built from tracked summary JSON only.

Two figures:

``protected_fraction_boundary``
    The paper's central claim. Structure-aware retention can only express a
    preference while the protected mass fits inside the keep budget. Plots the
    measured protected fraction of each workload against structure's accuracy
    there, with the budget line marking where the policy becomes oversubscribed.

``external_bfcl_arms``
    The paired five/six-arm BFCL table with Wilson intervals.

Nothing is hardcoded: every number is read from the summaries written by
``score_bfcl_external.py``, ``analyze_protected_fraction.py`` and
``audit_tau_retention.py``.
"""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

import matplotlib

matplotlib.use("Agg")
import matplotlib.pyplot as plt  # noqa: E402
import numpy as np  # noqa: E402

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT / "src"))

OUT = ROOT / "paper" / "figures"

# Colour-blind-safe, consistent across both figures.
ARM_COLOUR = {
    "full": "#4C4C4C",
    "snapkv": "#0072B2",
    "adapt": "#009E73",
    "structure": "#D55E00",
    "uniform": "#CC79A7",
    "random": "#999999",
}
ARM_LABEL = {
    "full": "FullKV",
    "snapkv": "SnapKV",
    "adapt": "ADAPT (ours)",
    "structure": "Structure",
    "uniform": "Uniform",
    "random": "Random",
}


def _load(path: Path) -> dict | None:
    if not path.is_file():
        print(f"[fig] missing {path}", file=sys.stderr)
        return None
    return json.loads(path.read_text())


def fig_protected_fraction(pf: dict, points: list[tuple[str, float, float]],
                           out: Path) -> None:
    """Protected fraction vs structure accuracy, with the budget threshold."""
    fig, ax = plt.subplots(figsize=(6.2, 4.0))

    budget = pf["workloads"][0]["keep_budget_fraction_mean"]
    ax.axvline(budget, color="black", ls="--", lw=1.2, zorder=1)
    ax.axvspan(budget, 1.02, color="#D55E00", alpha=0.06, zorder=0)
    ax.text(budget + 0.015, 0.86, "oversubscribed:\nstructure cannot rank",
            fontsize=8.5, color="#8a3b00", va="top")
    ax.text(budget - 0.015, 0.86, "structure can\nexpress a preference",
            fontsize=8.5, color="#333333", va="top", ha="right")

    for name, frac, acc in points:
        ax.scatter([frac], [acc], s=110, zorder=3,
                   color="#0072B2" if acc > 0.5 else "#D55E00",
                   edgecolor="white", linewidth=1.2)
        dy = -0.055 if acc > 0.5 else 0.035
        ax.annotate(f"{name}\n{frac:.1%} protected",
                    (frac, acc), textcoords="offset points",
                    xytext=(0, dy * 260), ha="center", fontsize=8.5)

    ax.set_xlabel("Protected-role fraction of the context")
    ax.set_ylabel("Structure-aware retention accuracy")
    ax.set_xlim(0, 1.02)
    ax.set_ylim(-0.08, 1.05)
    ax.set_xticks(np.arange(0, 1.01, 0.2))
    ax.xaxis.set_major_formatter(lambda v, _: f"{v:.0%}")
    ax.grid(alpha=0.25, linewidth=0.6)
    ax.set_title("Structure-aware retention works only below the keep budget",
                 fontsize=10.5)
    fig.tight_layout()
    fig.savefig(out, dpi=300)
    plt.close(fig)
    print(f"[fig] wrote {out}")


def fig_arms(summary: dict, out: Path) -> None:
    """Paired arm accuracies with Wilson intervals."""
    order = [a for a in ("full", "snapkv", "adapt", "structure", "uniform", "random")
             if a in summary.get("overall", {})]
    accs = [summary["overall"][a]["accuracy"] for a in order]
    lo = [summary["overall"][a]["accuracy"] - summary["overall"][a]["wilson_ci_low"]
          for a in order]
    hi = [summary["overall"][a]["wilson_ci_high"] - summary["overall"][a]["accuracy"]
          for a in order]

    fig, ax = plt.subplots(figsize=(6.2, 3.6))
    x = np.arange(len(order))
    ax.bar(x, accs, yerr=[lo, hi], capsize=4, width=0.62,
           color=[ARM_COLOUR[a] for a in order], edgecolor="white", linewidth=0.8)
    for xi, a in zip(x, accs):
        ax.text(xi, a + 0.012, f"{a:.3f}", ha="center", fontsize=9)

    ax.set_xticks(x)
    ax.set_xticklabels([ARM_LABEL[a] for a in order], fontsize=9)
    ax.set_ylabel("BFCL V3 multi-turn accuracy")
    n = summary.get("n_tasks_paired", 0)
    ax.set_title(
        f"BFCL V3 multi-turn, Qwen3-8B, 25% keep "
        f"(n={n} paired, official scorer)", fontsize=10.5)
    ax.grid(axis="y", alpha=0.25, linewidth=0.6)
    ax.set_axisbelow(True)
    fig.tight_layout()
    fig.savefig(out, dpi=300)
    plt.close(fig)
    print(f"[fig] wrote {out}")


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__)
    ap.add_argument("--results-root", required=True)
    ap.add_argument("--tag", default="primary")
    ap.add_argument("--pb-a-protected", type=float, default=0.061,
                    help="measured PriorityBench-A protected fraction")
    ap.add_argument("--pb-a-accuracy", type=float, default=0.933,
                    help="frozen PriorityBench-A structure accuracy (RESULTS.md)")
    ap.add_argument("--out", default=str(OUT))
    args = ap.parse_args()

    root = Path(args.results_root) / "summaries"
    out = Path(args.out)
    out.mkdir(parents=True, exist_ok=True)

    summary = _load(root / f"summary_{args.tag}.json")
    pf = _load(root / "protected_fraction.json")

    if pf is not None:
        by = {w["workload"]: w for w in pf["workloads"]}
        pts: list[tuple[str, float, float]] = [
            ("PriorityBench-A", args.pb_a_protected, args.pb_a_accuracy),
        ]
        if "tau-bench" in by:
            # tau is a retention audit, not a task-accuracy benchmark; plot its
            # any-token retention on buried spans as the comparable quantity.
            tau = _load(root / "tau_audit_summary.json")
            if tau:
                v = tau["by_policy"]["structure"]["by_visibility"]["buried"]
                pts.append(("tau-bench\n(buried-span retention)",
                            by["tau-bench"]["protected_fraction_mean"],
                            v.get("any_retained_rate", 0.0)))
        if "BFCL-all" in by and summary:
            pts.append(("BFCL V3 multi-turn",
                        by["BFCL-all"]["protected_fraction_mean"],
                        summary["overall"].get("structure", {}).get("accuracy", 0.0)))
        fig_protected_fraction(pf, pts, out / "external_protected_fraction.png")

    if summary is not None:
        fig_arms(summary, out / "external_bfcl_arms.png")

    print("EXTERNAL_FIGURES_OK")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
