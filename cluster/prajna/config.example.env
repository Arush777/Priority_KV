# Copy to cluster/prajna/config.env (git-ignored) and adjust for your account.
# NEVER commit config.env, tokens, or personal absolute paths.

# ---- Persistent project root (Prajna: only $HOME is writable) --------------
# /lustre-scratch, /lustre-flash and /scratch all reject user writes.
export PRAJNA_ROOT="$HOME/prioritykv_prajna"

# ---- Slurm ----------------------------------------------------------------
# Discovered on Prajna 2026-07-21 (see cluster/prajna/README.md):
#   partition l40 requires QOS l40      -> L40S 46GB, sm_89, max 2 days, 4 GPU/user
#   partition a40 requires QOS a40      -> A40 48GB,  sm_86, max 4 days, 2 GPU/user
#   partition dgx requires QOS dgx      -> A100-class, max 6 days, 4 GPU/user
#   partition debug requires QOS debug  -> 30 min, a40
# A partition's QOS is mandatory: submitting without it fails with
# "Invalid qos specification".
export PKV_PARTITION="l40"
export PKV_QOS="l40"
export PKV_CPU_PARTITION="l40"
export PKV_CPU_QOS="l40"
export PKV_GRES="gpu:1"
export PKV_CPUS_PER_TASK="8"
export PKV_MEM="96G"
export PKV_TIME="07:30:00"
# No Slurm account string is required for this association; set if yours is.
export PKV_ACCOUNT=""

# ---- Caches (all under PRAJNA_ROOT so nothing lands in a full $HOME) -------
export UV_CACHE_DIR="$PRAJNA_ROOT/uv-cache"
export HF_HOME="$PRAJNA_ROOT/hf-cache"
export TORCH_EXTENSIONS_DIR="$PRAJNA_ROOT/torch-extensions"
export XDG_CACHE_HOME="$PRAJNA_ROOT/xdg-cache"
export PRIORITYKV_SCRATCH="$PRAJNA_ROOT/scratch"

# ---- Pinned artefacts (staged on the LOGIN node; compute nodes have no DNS)-
export PKV_MODEL_DIR="$PRIORITYKV_SCRATCH/models/Qwen3-8B"
export PKV_GORILLA_ROOT="$PRAJNA_ROOT/gorilla"
export PKV_TAU_DIR="$PRAJNA_ROOT/datasets/tau_bench_trajectories"

# ---- Build / runtime ------------------------------------------------------
# L40S is Ada, sm_89. There is no sm_90 device anywhere on Prajna.
export TORCH_CUDA_ARCH_LIST="8.9"
export HF_HUB_OFFLINE="1"
export TRANSFORMERS_OFFLINE="1"
export TOKENIZERS_PARALLELISM="false"

# HF_TOKEN is only needed on the login node for staging. Never echo it.
# export HF_TOKEN=

# User-installed CUDA toolkit for FlashInfer JIT (no system nvcc on Prajna).
export PKV_CUDA_HOME="$PRAJNA_ROOT/cuda128"
